# Port the chat microservice listens on
CHAT_SERVICE_PORT=4040

# Directory where deltachat-rpc-server stores its SQLite databases and account data.
# Must exist and be writable. Backed up regularly (contains all message history).
# Dev:  ./dc-data  (relative to chat-service/ directory, created automatically)
# Prod: /var/data/dc-accounts
DC_ACCOUNTS_PATH=./dc-data

# Chatmail server domain
# Dev:  nine.testrun.org   (public testrun.org server — zero setup needed)
# Prod: chat.serey.io      (self-hosted on Hetzner, see DELTA_CHAT_SETUP.md Part 2)
CHATMAIL_DOMAIN=nine.testrun.org

# Optional: pin the bot account to a fixed address across restarts.
# Leave blank to auto-generate on first run (recommended for dev).
# BOT_ADDR=sereybot@chat.serey.io
# BOT_PASSWORD=your_secure_password_here
